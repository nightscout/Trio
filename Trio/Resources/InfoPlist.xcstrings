    "NSCalendarsFullAccessUsageDescription" : {
      "comment" : "Privacy - Calendars Full Access Usage Description",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "За създаване на събития със стойности на кръвната захар, за да се виждат в Apple Watch и CarPlay"
