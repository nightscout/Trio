    "NSContactsUsageDescription" : {
      "comment" : "Privacy - Contacts Usage Description",
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Позволява на Trio достъп до контактите Ви за актуализации на контакта на циферблата на Apple Watch чрез функцията „Contact Trick“."
          }
        },
        "cs" : {
          "stringUnit" : {
